{
  "name": "neuranet",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "ng": "ng",
    "start": "concurrently --kill-others-on-fail --names \"api,ui\" --prefix-colors \"yellow,cyan\" \"npm:start:api\" \"npm:start:ui\"",
    "start:api": "tsx server/index.ts",
    "start:ui": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "build:server": "tsc -p server/tsconfig.json",
    "vercel-build": "pnpm db:migrate && pnpm build && pnpm build:server",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --no-progress",
    "test:watch": "ng test",
    "test:server": "vitest run --config server/vitest.config.mjs",
    "lint": "ng lint && eslint server scripts",
    "format": "prettier --write \"src/**/*.ts\" \"server/**/*.ts\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"server/**/*.ts\" \"scripts/**/*.mjs\"",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.config.pg.ts",
    "db:migrate": "tsx server/db/migrate.ts"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pino": "^10.3.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/uuid": "^11.0.0",
    "@vercel/node": "^5.8.17",
    "angular-eslint": "22.0.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.0",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
