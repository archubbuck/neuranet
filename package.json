{
  "name": "neuranet",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "ng": "ng",
    "start": "concurrently --kill-others-on-fail --names \"api,ui\" --prefix-colors \"yellow,cyan\" \"npm:start:api\" \"npm:start:ui\"",
    "start:api": "node server/index.js",
    "start:ui": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --no-watch --no-progress",
    "test:watch": "ng test",
    "test:server": "vitest run --config server/vitest.config.mjs",
    "lint": "ng lint && eslint server scripts",
    "format": "prettier --write \"src/**/*.ts\" \"server/**/*.{js,mjs}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"server/**/*.{js,mjs}\" \"scripts/**/*.mjs\""
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "better-sqlite3": "^12.10.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular-eslint/builder": "22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "22.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.0",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
}
